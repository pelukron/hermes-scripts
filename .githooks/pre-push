#!/bin/bash
# Pre-push hook: bloquea push directo a main
# Regla: solo se permite push a main desde ramas de PR (no push directo)

branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" = "main" ]; then
    echo ""
    echo "🚫 PUSH DIRECTO A MAIN BLOQUEADO"
    echo ""
    echo "   Regla: Todo cambio debe pasar por PR."
    echo "   Usa: bump-and-pr.sh para crear Issue + rama + PR."
    echo ""
    echo "   Flujo correcto:"
    echo "     1. git checkout -b feat/mi-cambio"
    echo "     2. Hacer cambios + commit"
    echo "     3. ./bump-and-pr.sh patch 'feat: mi cambio' '- cambio'"
    echo "     4. Revisar PR en GitHub → merge"
    echo ""
    exit 1
fi